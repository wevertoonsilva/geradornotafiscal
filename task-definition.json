{
  "family": "geradornotafiscal",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::298660930243:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::298660930243:role/ecsTaskRole-geradornotafiscal",
  "containerDefinitions": [
    {
      "name": "geradornotafiscal",
      "image": "298660930243.dkr.ecr.us-east-1.amazonaws.com/geradornotafiscal:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE",  "value": "prod"              },
        { "name": "NEW_RELIC_APP_NAME",      "value": "geradornotafiscal" },
        { "name": "NEW_RELIC_LOG_LEVEL",     "value": "info"              },
        { "name": "NEW_RELIC_ACCOUNT_ID",    "value": "8065224"           },
        { "name": "NEW_RELIC_ENVIRONMENT",   "value": "prod"              }
      ],
      "secrets": [
        {
          "name": "NEW_RELIC_LICENSE_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:298660930243:secret:newrelic/license-key-s6dQFC"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/geradornotafiscal",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --spider -q http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
